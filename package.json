{
  "name": "@codecell-germany/sevdesk-agent-skill",
  "version": "0.1.8",
  "private": false,
  "description": "Agent-focused sevdesk CLI in TypeScript",
  "license": "MIT",
  "author": "Nikolas Gottschol",
  "bin": {
    "sevdesk-agent": "dist/index.js",
    "sevdesk-agent-skill": "dist/installer.js"
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean && tsc -p tsconfig.json && node scripts/ensure-executable.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:live": "vitest run tests/integration",
    "test:all": "vitest run",
    "prepack": "npm run build && node dist/index.js docs read-ops --output knowledge/READ_OPERATIONS.md"
  },
  "files": [
    "dist/**",
    "skills/**",
    "knowledge/OPENAPI_CLI_COVERAGE_CHECKLIST.json",
    "knowledge/OPENAPI_CLI_COVERAGE_CHECKLIST.md",
    "knowledge/READ_OPERATIONS.md",
    "knowledge/SEVDESK_ACCOUNTING_AUTOMATION_CONCEPT.md",
    "knowledge/SEVDESK_BREAKING_CHANGES.md",
    "knowledge/SEVDESK_MINIMAL_CALL_WORKFLOW.md",
    "knowledge/SEVDESK_ORDER_WRITE_LEARNINGS.md",
    "knowledge/SEVDESK_SKILL_IMPROVEMENT_LIST.md",
    "knowledge/SKILL_PUBLISHING_GUIDE.md",
    "OPERATIONS.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^6.0.2",
    "vitest": "^4.0.18"
  }
}
